# =====================================================================
# PaperClip — Variables d'environnement pour le déploiement VPS
# Copier ce fichier en .env sur le serveur et remplir les valeurs
# NE JAMAIS commiter le fichier .env !
# =====================================================================

# --- Base de données ---
DATABASE_URL=postgres://paperclip:CHANGE_MOI@localhost:5432/paperclip
POSTGRES_USER=paperclip
# Générer avec : openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_MOI

# --- Authentification (Better Auth) ---
# CRITIQUE : générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_MOI

# --- Déploiement ---
PORT=3100
SERVE_UI=true
# IMPORTANT : toujours "authenticated" sur un VPS public
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
# Remplacer par ton IP ou domaine Hostinger
PAPERCLIP_PUBLIC_URL=http://TON_IP_HOSTINGER:3100
